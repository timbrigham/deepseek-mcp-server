# DeepSeek API Key (required)
# Get your API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your-api-key-here

# Base URL for DeepSeek API (optional)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Show cost information in responses (optional, default: true)
# SHOW_COST_INFO=true

# Request timeout in milliseconds (optional, default: 60000)
# REQUEST_TIMEOUT=60000

# Maximum number of retries (optional, default: 2)
# MAX_RETRIES=2

# Max server-side repair retries when a deepseek_chat response_schema fails
# validation (optional, default: 2). Set to 0 for a strictly deterministic
# single call with no extra API round-trips.
# RESPONSE_SCHEMA_MAX_RETRIES=2
