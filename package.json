{
  "name": "@arikusi/deepseek-mcp-server",
  "version": "2.1.0",
  "mcpName": "io.github.arikusi/deepseek",
  "description": "MCP Server for DeepSeek API integration - enables Claude Code to use DeepSeek Chat and Reasoner models",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "deepseek-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "deepseek",
    "deepseek-api",
    "deepseek-chat",
    "deepseek-reasoner",
    "deepseek-r1",
    "claude-code",
    "ai",
    "llm",
    "openai-compatible",
    "function-calling",
    "tool-use",
    "session-management",
    "circuit-breaker",
    "model-fallback",
    "gemini-cli",
    "mcp-server",
    "docker",
    "http-transport",
    "streamable-http"
  ],
  "author": "arikusi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arikusi/deepseek-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/arikusi/deepseek-mcp-server/issues"
  },
  "homepage": "https://github.com/arikusi/deepseek-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
