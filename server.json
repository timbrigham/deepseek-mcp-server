{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.arikusi/deepseek",
  "description": "MCP server for DeepSeek AI — chat, reasoning, sessions, fallback, function calling",
  "repository": {
    "url": "https://github.com/arikusi/deepseek-mcp-server",
    "source": "github"
  },
  "version": "1.4.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@arikusi/deepseek-mcp-server",
      "version": "1.4.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DEEPSEEK_API_KEY",
          "description": "DeepSeek API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
